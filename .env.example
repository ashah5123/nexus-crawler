# =============================================================================
# nexus-crawler — distributed web scraping system configuration
# Copy this file to .env and adjust values for your environment.
# =============================================================================

# Redis connection URL (used for job queue and coordination)
REDIS_URL=redis://localhost:6379

# Orchestrator server bind address and port
ORCHESTRATOR_HOST=0.0.0.0
ORCHESTRATOR_PORT=8000

# Alternative env var names used by some runners (optional)
HOST=0.0.0.0
PORT=8000

# How many URLs a single worker scrapes in parallel
WORKER_CONCURRENCY=4

# Unique ID for this worker instance (override per worker when running multiple)
WORKER_ID=worker-1

# Maximum number of retries for failed scrape requests
MAX_RETRIES=3

# Delay in seconds between retries
RETRY_DELAY_SECONDS=5

# Per-domain rate limit: max requests per second
RATE_LIMIT_REQUESTS_PER_SECOND=2

# Timeout in seconds for each scrape request
SCRAPE_TIMEOUT_SECONDS=30

# How often workers send heartbeats to the orchestrator (seconds)
HEARTBEAT_INTERVAL_SECONDS=10

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
